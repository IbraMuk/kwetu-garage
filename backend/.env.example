# Configuration de la base de données
# ─────────────────────────────────────────────────────────────────────────────
# Erreur 28P01 = mot de passe ou utilisateur PostgreSQL incorrect dans .env
#
# Option A — une seule ligne (souvent plus simple, ex. Neon / Supabase / copie pgAdmin) :
# DATABASE_URL=postgresql://postgres:VOTRE_MOT_DE_PASSE@localhost:5432/kwetu_garage
# Pour un hébergeur qui exige SSL : DATABASE_SSL=true
#
# Option B — variables séparées (décommentez et remplissez si vous n'utilisez pas DATABASE_URL) :
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=kwetu_garage
# DB_USER=postgres
# DB_PASSWORD=le_même_mot_de_passe_que_dans_pgAdmin
#
# Ne laissez pas DB_PASSWORD=votre_mot_de_passe (placeholder) : PostgreSQL refusera toujours.
# Redémarrez le backend après modification. Test : GET http://localhost:PORT/api/health
# ─────────────────────────────────────────────────────────────────────────────

DB_HOST=localhost
DB_PORT=5432
DB_NAME=kwetu_garage
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe

# Configuration du serveur (éviter le port 3000 : réservé à Next.js)
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=votre_jwt_secret_très_long_et_sécurisé
JWT_EXPIRE=7d

# CORS — origines autorisées (séparées par des virgules)
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
