# API Express + PostgreSQL (backend sur le port 3001)
# Copiez vers .env :  cp .env.example .env

# Émulateur Android (défaut dans le code : 10.0.2.2:3001)
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3001/api

# Simulateur iOS / web Expo
# EXPO_PUBLIC_API_URL=http://localhost:3001/api

# Téléphone physique (même Wi‑Fi que le PC — remplacez par l’IP du PC)
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3001/api

EXPO_PUBLIC_API_URL=http://localhost:3001/api
